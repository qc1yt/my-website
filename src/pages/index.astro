---
// トップページのデザインとロジックを記述．

import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// 1. DIARYの取得とソート
const diaryEntries = await getCollection('diary').catch(() => []);
const sortedDiaryEntries = diaryEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// 2. TECH NOTESの取得とソート
const techEntries = await getCollection('tech').catch(() => []);
const sortedTech = techEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// 3. SOFTWARE & TOOLSの取得とソート
const softwareEntries = await getCollection('software').catch(() => []);
const sortedSoftware = softwareEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// 4. PAPER REVIEWSの取得とソート
const papersEntries = await getCollection('papers').catch(() => []);
const sortedPapers = papersEntries.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Layout>
    <main>
        <section class="hero reveal">
            <h1 class="hero-title">
                <span class="block-reveal delay-1">THERMODYNAMICS,</span><br>
                <span class="block-reveal delay-2">ENGINEERING</span><br>
                <span class="block-reveal delay-3">& REFLECTIONS.</span>
            </h1>
            <p class="hero-subtitle block-reveal delay-4">工学系の探求、学術研究の記録、そして日々の備忘録。</p>
        </section>

        <section id="diary" class="section reveal">
            <h2 class="section-title">01 DIARY</h2>
            <div class="diary-feed">
                {sortedDiaryEntries.map(entry => (
                    <article class="diary-entry">
                        <div class="diary-meta">
                            <time datetime={entry.data.date.toISOString()}>
                                {entry.data.date.toISOString().slice(0, 10).replace(/-/g, '.')}
                            </time>
                            {entry.data.tags && entry.data.tags.length > 0 && (
                                <span class="tag">{entry.data.tags[0]}</span>
                            )}
                        </div>
                        <div class="diary-summary">
                            <a href={`/diary/${entry.slug}`} class="diary-title-link">
                                {entry.data.title}
                            </a>
                        </div>
                    </article>
                ))}
            </div>
        </section>

        <section id="tech" class="section reveal">
            <h2 class="section-title">02 TECH NOTES</h2>
            <div class="bento-grid">
                {sortedTech.map((entry, index) => (
                    <a href={`/tech/${entry.slug}`} class={`card ${index === 0 ? 'card-large' : ''} glass-effect hover-trigger`}>
                        <div class="card-content">
                            <h3 class="card-title">{entry.data.title}</h3>
                            <p class="card-description">{entry.data.description}</p>
                            <p class="card-meta">
                                {entry.data.tags && entry.data.tags[0] && <span class="badge">{entry.data.tags[0]}</span>}
                                {entry.data.date.toISOString().slice(0, 10).replace(/-/g, '.')}
                            </p>
                        </div>
                    </a>
                ))}
            </div>
        </section>

        <section id="software" class="section reveal">
            <h2 class="section-title">03 SOFTWARE & TOOLS</h2>
            <div class="bento-grid">
                {sortedSoftware.map((entry, index) => (
                    <a href={`/software/${entry.slug}`} class={`card ${index === 0 ? 'card-large' : ''} glass-effect hover-trigger`}>
                        <div class="card-content">
                            <h3 class="card-title">{entry.data.title}</h3>
                            <p class="card-description">{entry.data.description}</p>
                            <p class="card-meta">
                                {entry.data.tags && entry.data.tags[0] && <span class="badge">{entry.data.tags[0]}</span>}
                            </p>
                        </div>
                    </a>
                ))}
            </div>
        </section>

        <section id="papers" class="section reveal">
            <h2 class="section-title">04 PAPER REVIEWS</h2>
            <div class="bento-grid">
                {sortedPapers.map((entry, index) => (
                    <a href={`/papers/${entry.slug}`} class={`card ${index === 0 ? 'card-large' : ''} glass-effect hover-trigger`}>
                        <div class="card-content">
                            <h3 class="card-title">{entry.data.title}</h3>
                            <p class="card-description">{entry.data.description}</p>
                            <p class="card-meta">
                                {entry.data.tags && entry.data.tags[0] && <span class="badge">{entry.data.tags[0]}</span>}
                                {entry.data.date.toISOString().slice(0, 10).replace(/-/g, '.')}
                            </p>
                        </div>
                    </a>
                ))}
            </div>
        </section>
    </main>
</Layout>
